# *** 7. dispose: {$50} @ $55. Disposal detected.
# Also shows that a Gain-type account can be declared explicitly with type: G.
<
commodity AAPL  ; lots:
account capital gains  ; type: G

2026-01-01 buy
    assets:broker    10 AAPL {$50}
    assets:cash     -$500

2026-02-01 sell
    assets:broker    -5 AAPL {$50} @ $55
    assets:cash      $275
    capital gains   -$25

$ hledger -f- print desc:sell --lots --verbose-tags
2026-02-01 sell
    assets:broker:{2026-01-01, $50}    -5 AAPL {$50} @ $55  ; ptype: dispose
    assets:cash                                       $275
    capital gains                                     $-25  ; ptype: gain
    equity:unrealised-gain                             $25  ; ptype: ugain, generated-posting:

>=

# *** 8. dispose: {$50} @@ $275. Disposal detected.
<
commodity AAPL  ; lots:
account revenue:gains  ; type:G

2026-01-01 buy
    assets:broker    10 AAPL {$50}
    assets:cash     -$500

2026-02-01 sell
    assets:broker    -5 AAPL {$50} @@ $275
    assets:cash      $275
    revenue:gains   -$25

$ hledger -f- print desc:sell --lots --verbose-tags
2026-02-01 sell
    assets:broker:{2026-01-01, $50}    -5 AAPL {$50} @@ $275  ; ptype: dispose
    assets:cash                                         $275
    revenue:gains                                       $-25  ; ptype: gain
    equity:unrealised-gain                               $25  ; ptype: ugain, generated-posting:

>=

# ** Disposal balancing validation

# *** 9. dispose at cost: no gain/loss, transaction balances at cost basis.
<
commodity AAPL  ; lots:

2026-01-01 buy
    assets:broker    10 AAPL {$50}
    assets:cash     -$500

2026-02-01 sell
    assets:broker    -5 AAPL {$50} @ $50
    assets:cash      $250

$ hledger -f- print desc:sell --lots --verbose-tags
2026-02-01 sell
    assets:broker:{2026-01-01, $50}    -5 AAPL {$50} @ $50  ; ptype: dispose
    assets:cash                                       $250

>=

# *** 10. dispose: wrong gain amount. Disposal balancing rejects this.
<
commodity AAPL  ; lots:
account revenue:gains  ; type:G

2026-01-01 buy
    assets:broker    10 AAPL {$50}
    assets:cash     -$500

2026-02-01 sell
    assets:broker    -5 AAPL {$50} @ $55
    assets:cash      $275
    revenue:gains   -$30

$ hledger -f- print desc:sell --lots --verbose-tags
>2 /realised gain amount is wrong/
>=1

# *** 11. dispose: missing gain posting is inferred from Gain account.
<
commodity AAPL  ; lots:
account revenue:gains  ; type: G

2026-01-01 buy
    assets:broker    10 AAPL {$50}
    assets:cash     -$500

2026-02-01 sell
    assets:broker    -5 AAPL {$50} @ $55
    assets:cash      $275

$ hledger -f- print desc:sell --lots --verbose-tags
2026-02-01 sell
    assets:broker:{2026-01-01, $50}    -5 AAPL {$50} @ $55  ; ptype: dispose
    assets:cash                                       $275
    revenue:gains                                     $-25  ; ptype: rgain, generated-posting:
    equity:unrealised-gain                             $25  ; ptype: ugain, generated-posting:

>=

# *** 12. dispose: missing gain posting, no Gain account declared → defaults to revenue:gains.
<
commodity AAPL  ; lots:
account revenue:gains  ; type:G

2026-01-01 buy
    assets:broker    10 AAPL {$50}
    assets:cash     -$500

2026-02-01 sell
    assets:broker    -5 AAPL {$50} @ $55
    assets:cash      $275

$ hledger -f- print desc:sell --lots --verbose-tags
2026-02-01 sell
    assets:broker:{2026-01-01, $50}    -5 AAPL {$50} @ $55  ; ptype: dispose
    assets:cash                                       $275
    revenue:gains                                     $-25  ; ptype: rgain, generated-posting:
    equity:unrealised-gain                             $25  ; ptype: ugain, generated-posting:

>=

# *** 13. dispose at cost basis (sale price = lot basis) → no gain pair.
<
2026-01-01 buy
    assets:broker    10 AAPL {$50}
    assets:cash

2026-02-01 sell at cost
    assets:broker    -5 AAPL {$50} @ $50
    assets:cash      $250

$ hledger -f- print desc:sell --lots
2026-02-01 sell at cost
    assets:broker:{2026-01-01, $50}    -5 AAPL {$50} @ $50
    assets:cash                                       $250

>=

# *** 14. An acquire with cost-basis != transacted-cost is rejected.
<
2026-01-01 weird buy with basis typo
    assets:broker    100 AAPL {$60} @ $50
    assets:cash     -$5000

$ hledger -f- print --lots
>2 /differs from its transacted cost/
>=1

# *** 15. Total basis cost / transacted cost are shown as unit costs in the error message,
# with non-terminating decimals capped at 8 decimal places (defaultMaxPrecision).
<
2026-01-01 weird buy
    assets:broker    7 AAPL {{$53}} @@ $50
    assets:cash     -$50

$ hledger -f- print --lots
>2 /cost basis \(\$7\.57142857\) differs from its transacted cost \(\$7\.14285714\)/
>=1
