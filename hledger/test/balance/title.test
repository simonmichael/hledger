# * --title option

# ** 1. default heading is the auto-generated title
<
2024/1/1
  (a)  1
2024/2/1
  (a)  1
$ hledger -f- balance --monthly
Balance changes in 2024-01-01..2024-02-29:

   || Jan  Feb 
===++==========
 a ||   1    1 
---++----------
   ||   1    1 

# ** 2. --title=TEXT overrides the default
<
2024/1/1
  (a)  1
2024/2/1
  (a)  1
$ hledger -f- balance --monthly '--title=My monthly view'
My monthly view

   || Jan  Feb 
===++==========
 a ||   1    1 
---++----------
   ||   1    1 

# ** 3. --title= suppresses the default
<
2024/1/1
  (a)  1
2024/2/1
  (a)  1
$ hledger -f- balance --monthly --title=
   || Jan  Feb 
===++==========
 a ||   1    1 
---++----------
   ||   1    1 

# ** 4. --title also affects compound reports' txt output
<
2024/1/1
  (a)  1
2024/2/1
  (a)  1
$ hledger -f- balancesheet --quarterly '--title=Custom BS'
Custom BS

             || 2024-03-31 
=============++============
 Assets      ||            
-------------++------------
-------------++------------
             ||          0 
=============++============
 Liabilities ||            
-------------++------------
-------------++------------
             ||          0 
=============++============
 Net:        ||          0 

# ** 5. --title affects compound CSV title row
<
2024/1/1
  (a)  1
2024/2/1
  (a)  1
$ hledger -f- balancesheet --quarterly --title=Hi -O csv
"Hi",""
"Account","2024-03-31"
"Assets",""
"Total:","0"
"Liabilities",""
"Total:","0"
"Net:","0"

# ** 6. --title= suppresses compound CSV title row
<
2024/1/1
  (a)  1
2024/2/1
  (a)  1
$ hledger -f- balancesheet --quarterly --title= -O csv
"Account","2024-03-31"
"Assets",""
"Total:","0"
"Liabilities",""
"Total:","0"
"Net:","0"

# ** 7. --title also affects compound TSV title row (parity with CSV)
<
2024/1/1
  (a)  1
2024/2/1
  (a)  1
$ hledger -f- balancesheet --quarterly --title=Hi -O tsv
Hi	
Account	2024-03-31
Assets	
Total:	0
Liabilities	
Total:	0
Net:	0

# ** 8. --title= suppresses compound TSV title row
<
2024/1/1
  (a)  1
2024/2/1
  (a)  1
$ hledger -f- balancesheet --quarterly --title= -O tsv
Account	2024-03-31
Assets	
Total:	0
Liabilities	
Total:	0
Net:	0

# ** 9. --title=X is shown above the table for the simple balance
<
2024/1/1
  (a)  1
2024/2/1
  (a)  1
$ hledger -f- balance --title=Hi
Hi

                   2  a
--------------------
                   2  

