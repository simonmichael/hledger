# *** 13. dispose at cost basis (sale price = lot basis) → no gain pair.
<
2026-01-01 buy
    assets:broker    10 AAPL {$50}
    assets:cash

2026-02-01 sell at cost
    assets:broker    -5 AAPL {$50} @ $50
    assets:cash      $250

$ hledger -f- print desc:sell --lots
2026-02-01 sell at cost
    assets:broker:{2026-01-01, $50}               -5 AAPL {$50} @ $50
    assets:cash                                 $250

>=

# *** 14. dispose with an explicit gain posting to an undeclared account.
# The imbalance is assumed to be rgain; a corresponding ugain posting is inferred.
<
commodity AAPL  ; lots:

2026-01-01 buy
    assets:broker    10 AAPL {$50}
    assets:cash     -$500

2026-02-01 sell
    assets:broker    -5 AAPL {$50} @ $55
    assets:cash      $275
    revenues:gain   $-25

$ hledger -f- print desc:sell --lots --verbose-tags
2026-02-01 sell
    assets:broker:{2026-01-01, $50}               -5 AAPL {$50} @ $55  ; ptype: dispose
    assets:cash                                 $275
    revenues:gain                               $-25  ; ptype: gain
    equity:unrealised-gain                       $25  ; ptype: ugain, generated-posting:

>=

# *** 15. dispose with wrong gain amount on an undeclared account → rejected.
<
commodity AAPL  ; lots:

2026-01-01 buy
    assets:broker    10 AAPL {$50}
    assets:cash     -$500

2026-02-01 sell
    assets:broker    -5 AAPL {$50} @ $55
    assets:cash      $275
    revenues:gain   $-10

$ hledger -f- print desc:sell --lots
>2 /This disposal's realised gain amount is wrong/
>=1

# *** 16. dispose with typo'd cash and no gain posting → balance error.
# Heuristic gain posting detection find no gain posting,
# letting the standard balancer surface the cash imbalance.
<
commodity AAPL  ; lots:

2026-01-01 buy
    assets:broker    10 AAPL {$50}
    assets:cash     -$500

2026-02-01 sell
    assets:broker    -5 AAPL {$50} @ $55
    assets:cash      $250        ; typo, should be $275

$ hledger -f- print desc:sell --lots
>2 /unbalanced/
>=1

# *** 17. dispose with typo'd cash plus correct rgain on undeclared account → balance error.
# The non-candidate postings' sum is single-commodity non-zero, so no gain posting is detected,
# and the balancer reports the imbalance.
<
commodity AAPL  ; lots:

2026-01-01 buy
    assets:broker    10 AAPL {$50}
    assets:cash     -$500

2026-02-01 sell
    assets:broker    -5 AAPL {$50} @ $55
    assets:cash      $250        ; typo, should be $275
    revenues:gain   $-25

$ hledger -f- print desc:sell --lots
>2 /unbalanced/
>=1

# *** 18. multi-lot dispose with per-lot gains postings.
# All gain postings are detected and a single balancing ugain posting is inferred.
<
commodity AAPL  ; lots:

2026-01-01 buy lot1
    assets:broker     5 AAPL {$50}
    assets:cash    -$250

2026-01-15 buy lot2
    assets:broker     3 AAPL {$55}
    assets:cash    -$165

2026-02-01 sell some of each
    assets:broker    -5 AAPL {$50} @ $60
    assets:broker    -3 AAPL {$55} @ $60
    assets:cash     $480
    revenues:gain   $-50         ; gain on lot1
    revenues:gain   $-15         ; gain on lot2

$ hledger -f- print desc:sell --lots --verbose-tags
2026-02-01 sell some of each
    assets:broker:{2026-01-01, $50}               -5 AAPL {$50} @ $60  ; ptype: dispose
    assets:broker:{2026-01-15, $55}               -3 AAPL {$55} @ $60  ; ptype: dispose
    assets:cash                                 $480
    revenues:gain                               $-50  ; ptype: gain, gain on lot1
    revenues:gain                               $-15  ; ptype: gain, gain on lot2
    equity:unrealised-gain                       $65  ; ptype: ugain, generated-posting:

>=

# *** 19. method-1 inferred gain is rounded to the entry's local precision,
# hiding sub-cent noise from B-T arithmetic. Here 9.216 × 1801.215277778
# = 16600.000000002, so the calculated gain is Rs2803.240000002... but the
# entry's local Rs precision is 2 dp (from Rs19403.24), so the inferred
# rgain/ugain are saved at 2 dp.
<
2017-04-09 buy
    assets:fund    9.216 FUND {Rs1801.215277778}
    assets:savings                   Rs-16600.00

2019-07-10 sell
    assets:savings                                     Rs19403.24
    assets:fund    -9.216 FUND {Rs1801.215277778} @@ Rs19403.24

$ hledger -f- print desc:sell --lots
2019-07-10 sell
    assets:savings                              Rs19403.24
    assets:fund:{2017-04-09, Rs1801.215277778}       -9.216 FUND {Rs1801.215277778} @@ Rs19403.24
    revenues:gain                               Rs-2803.24
    equity:unrealised-gain                       Rs2803.24

>=

# *** 20. A user-written rgain that differs from the calculated gain by more
# than half a ULP at the entry's local precision is rejected, and the error
# message shows the actual amounts at full precision (so any real
# discrepancy is visible).
<
account income:capital  ; type:G

2017-04-09 buy
    assets:fund    9.216 FUND {Rs1801.215277778}
    assets:savings                   Rs-16600.00

2019-07-10 sell
    assets:savings                                     Rs19403.24
    assets:fund    -9.216 FUND {Rs1801.215277778} @@ Rs19403.24
    income:capital                                     Rs-2803.30

$ hledger -f- print --lots
>2
hledger: Error: -:7:
7 | 2019-07-10 sell
  |     assets:savings                              Rs19403.24
  |     assets:fund:{2017-04-09, Rs1801.215277778}       -9.216 FUND {2017-04-09, Rs1801.215277778} @@ Rs19403.24
  |     income:capital                              Rs-2803.30
  |     equity:unrealised-gain                       Rs2803.30

This disposal's realised gain amount is wrong.
  written:    Rs-2803.30
  calculated: Rs-2803.239999997952
>=1

