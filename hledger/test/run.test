# * run command

# ** 1. Run requires -- before first command
<
2017-01-01 groceries
   assets:cash  -$100
   expenses:food
$ hledger run -f- aregister cash
>2 /Error: aregister: openFile: does not exist \(No such file or directory\)/
>=1

# ** 2. Run refuses to read input file and commands from stdin
<
$ hledger run -f-
>2 /Error: 'run' can't read commands from stdin, as one of the input files was stdin as well/
>=1

# ** 3. Run one command from command line
<
2017-01-01 groceries
   assets:cash  -$100
   expenses:food
$ hledger run -f- -- register cash
>
2017-01-01 groceries            assets:cash                  $-100         $-100


# ** 4. Run two commands from command line
<
2017-01-01 groceries
   assets:cash  -$100
   expenses:food
$ hledger run -f- -- echo "Cash:" -- register cash -- echo 'Food:' -- register food
>
Cash:
2017-01-01 groceries            assets:cash                  $-100         $-100
Food:
2017-01-01 groceries            expenses:food                 $100          $100

# ** 5. Run two commands from command line with different input options
<
2017-01-01 investment
   assets:cash  -$100
   expenses:food

~ 2017-02-01  next month groceries
   assets:cash  -$120
   expenses:food
$ hledger run -f- -- register cash -- echo '=====' -- register --forecast food
>
2017-01-01 investment           assets:cash                  $-100         $-100
=====
2017-01-01 investment           expenses:food                 $100          $100
2017-02-01 next month grocer..  expenses:food                 $120          $220

# ** 6. Run commands from file
<
2017-01-01 groceries
   assets:cash  -$100
   expenses:food
$ hledger run -f- run_cmds.txt
>
Cash:
2017-01-01 groceries            assets:cash                  $-100         $-100
Food:
2017-01-01 groceries            expenses:food                 $100          $100

# ** 7. Run commands from command line, and use nested "run" to run commands from file
<
2017-01-01 groceries
   assets:cash  -$100
   expenses:food
$ hledger run -f- -- echo "Accounts:" -- accounts -- run run_cmds.txt -- echo "Balance:" -- balance cash
>
Accounts:
assets:cash
expenses:food
Cash:
2017-01-01 groceries            assets:cash                  $-100         $-100
Food:
2017-01-01 groceries            expenses:food                 $100          $100
Balance:
               $-100  assets:cash
--------------------
               $-100  

# ** 8. Run commands from stdin
<
echo 'Accounts:'
accounts
echo
echo 'Assets:'
balance assets
$ hledger run -f sample.journal
>
Accounts:
assets:bank:checking
assets:bank:saving
assets:cash
expenses:food
expenses:supplies
income:gifts
income:salary
liabilities:debts

Assets:
                  $1  assets:bank:saving
                 $-2  assets:cash
--------------------
                 $-1  


# ** 9. Run commands accept numeric options
<
echo 'Assets, depth 1:'
balance assets -1
echo
echo 'Assets, depth 2:'
balance assets -2
$ hledger run -f sample.journal
>
Assets, depth 1:
                 $-1  assets
--------------------
                 $-1  

Assets, depth 2:
                  $1  assets:bank
                 $-2  assets:cash
--------------------
                 $-1  

# ** 10. Run commands accept @ARGFILEs
<
echo 'Assets, depth 1:'
balance @run.args
echo
echo 'Assets, depth 2:'
balance assets -2
$ hledger run -f sample.journal
>
Assets, depth 1:
                 $-1  assets
--------------------
                 $-1  

Assets, depth 2:
                  $1  assets:bank
                 $-2  assets:cash
--------------------
                 $-1  

# ** 11. Run caches input files, and re-parses files when InputOptions change
<
2017-01-01 groceries
   assets:cash  -$100
   expenses:food
$ hledger run --debug 1 -f- -- accounts -- balance -f sample.journal -- balance cash --forecast -- balance cash -f sample.journal --forecast -- register -- register -f sample.journal 2>&1 | grep readAndCacheJournalFile | sed -e "s#$(pwd)/##"
>
readAndCacheJournalFile reading and caching -:
readAndCacheJournalFile reading and caching sample.journal:
readAndCacheJournalFile reading and caching -:
readAndCacheJournalFile reading and caching sample.journal:
readAndCacheJournalFile using cache for -:
readAndCacheJournalFile using cache for sample.journal:

# ** 12. Run commands with forecast properly honor reporting interval
<
2025-01-01  Buy beans
    expenses:food   $2
    assets         -$2

~ every 14 days from 2025-01-01  Buy soylent green
    expenses:food:not people   $1
    assets                    -$1
$ hledger run -f- -- echo "Till Feb" -- register --forecast -b 2025-01 -e 2025-02 -- echo "Till Mar" -- register --forecast -b 2025-01 -e 2025-03
>
Till Feb
2025-01-01 Buy beans            expenses:food                   $2            $2
                                assets                         $-2             0
2025-01-15 Buy soylent green    ex:food:not people              $1            $1
                                assets                         $-1             0
2025-01-29 Buy soylent green    ex:food:not people              $1            $1
                                assets                         $-1             0
Till Mar
2025-01-01 Buy beans            expenses:food                   $2            $2
                                assets                         $-2             0
2025-01-15 Buy soylent green    ex:food:not people              $1            $1
                                assets                         $-1             0
2025-01-29 Buy soylent green    ex:food:not people              $1            $1
                                assets                         $-1             0
2025-02-12 Buy soylent green    ex:food:not people              $1            $1
                                assets                         $-1             0
2025-02-26 Buy soylent green    ex:food:not people              $1            $1
                                assets                         $-1             0

# ** 13. Run propagates its general input flags (eg -I) to the commands it runs
<
2017-01-01
   assets:cash  $10 = $999
   equity
$ hledger run -f- -I -- balance
                 $10  assets:cash
                $-10  equity
--------------------
                   0  

# ** 14. A command's own input flags override run's (eg --strict overrides -I)
<
2017-01-01
   assets:cash  $10 = $999
   equity
$ hledger run -f- -I -- balance --strict
>2 /Balance assertion failed in assets:cash/
>=1

# ** 15. Run propagates other general input flags too (eg --pivot)
<
2017-01-01 shop  ; cat:groceries
   expenses  $10
   assets
$ hledger run -f- --pivot cat -- accounts
groceries

# ** 16. Run propagates general output/report flags too (eg --depth)
<
2017-01-01
   a:b  $1
   c
$ hledger run -f- --depth 1 -- balance
                  $1  a
                 $-1  c
--------------------
                   0  

# ** 17. A command's own report flags override run's (eg --depth 2 overrides --depth 1)
<
2017-01-01
   a:b  $1
   c
$ hledger run -f- --depth 1 -- balance --depth 2
                  $1  a:b
                 $-1  c
--------------------
                   0  

# ** 18. repl (and run reading commands from stdin) supports the ! shell escape
<
! echo hello
accounts
! echo bye
$ hledger repl -f sample.journal
>
hello
assets:bank:checking
assets:bank:saving
assets:cash
expenses:food
expenses:supplies
income:gifts
income:salary
liabilities:debts
bye
>=0

# ** 19. repl auto-reloads an input file after it changes on disk (using ! to modify it mid-session).
# The reload notice is printed on stderr; a bad edit keeps the previous version.
<
balance
! printf '\n2017-02-02 y\n  a  5\n  b\n' >> "$HLEDGER_RELTEST"
balance
$ sh -c 'export HLEDGER_RELTEST=$(mktemp "${TMPDIR:-/tmp}/hledger-reltest.XXXXXX"); printf "2017-01-01 x\n  a  1\n  b\n" > "$HLEDGER_RELTEST"; hledger repl -f "$HLEDGER_RELTEST"; rm -f "$HLEDGER_RELTEST"'
>
                   1  a
                  -1  b
--------------------
                   0  
                   6  a
                  -6  b
--------------------
                   0  
>2 /\(reloading /

# ** 20. repl auto-reloads config-file command aliases when the config file changes.
# foo is an alias for accounts, changed to balance mid-session; the second foo runs balance.
<
foo
! printf '[alias]\nfoo = balance\n' > "$HLEDGER_RELCONF"
foo
$ sh -c 'export HLEDGER_RELCONF=$(mktemp "${TMPDIR:-/tmp}/hledger-relconf.XXXXXX"); J=$(mktemp "${TMPDIR:-/tmp}/hledger-relj.XXXXXX"); printf "[alias]\nfoo = accounts\n" > "$HLEDGER_RELCONF"; printf "2017-01-01 x\n  a  1\n  b\n" > "$J"; hledger repl --conf "$HLEDGER_RELCONF" -f "$J"; rm -f "$HLEDGER_RELCONF" "$J"'
>
a
b
                   1  a
                  -1  b
--------------------
                   0  
>2 /\(reloading /
