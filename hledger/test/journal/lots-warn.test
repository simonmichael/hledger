# Testing --lots-warn mode.

# ** 1. --lots-warn implies --lots; insufficient lots exits 0 (posting passes through unchanged)
<
2026-01-15 buy
    assets:stocks    10 AAPL {$50}
    assets:checking

2026-02-01 sell
    assets:stocks    -15 AAPL {$50} @ $55
    assets:cash       $825
    revenues:gains

$ hledger -f- print --lots-warn 2>/dev/null
2026-01-15 buy
    assets:stocks:{2026-01-15, $50}    10 AAPL {$50}
    assets:checking

2026-02-01 sell
    assets:stocks     -15 AAPL {$50} @ $55
    assets:cash                       $825
    revenues:gains

>=0

# ** 2. no lots available with --lots-warn exits 0
<
2026-02-01 sell
    assets:stocks    -5 AAPL {$50} @ $55
    assets:cash       $275
    revenues:gains

$ hledger -f- print --lots-warn 2>/dev/null
2026-02-01 sell
    assets:stocks     -5 AAPL {$50} @ $55
    assets:cash                      $275
    revenues:gains

>=0

# ** 3. without --lots-warn, same input errors (exits 1)
<
2026-02-01 sell
    assets:stocks    -5 AAPL {$50} @ $55
    assets:cash       $275
    revenues:gains

$ hledger -f- print --lots 2>/dev/null
>=1

# ** 4. transfer with lot selection failure warns and passes through with --lots-warn
<
account assets:x1  ; type:A, lots: FIFO
account assets:x2  ; type:A, lots: FIFO

2026-02-01 transfer
    assets:x1    -5 AAPL {$50}
    assets:x2     5 AAPL {}

$ hledger -f- print --lots-warn 2>/dev/null
2026-02-01 transfer
    assets:x1    -5 AAPL {$50}
    assets:x2        5 AAPL {}

>=0

# ** 5. Unclassified lotful commodity posting in asset account warns with --lots-warn.
# AAPL has lots: tag, assets:broker is an asset account, but the posting has no cost basis
# and no price, so classification fails. With --lots-warn we get a warning on stderr.
<
commodity AAPL  ; lots:

2026-01-15 mysterious
    assets:broker    10 AAPL
    income:mystery

$ hledger -f- bal assets --lots-warn 2>&1
>  /was not classified/
>=0

# ** 6. Same input without --lots-warn passes silently (no warning, no error).
<
commodity AAPL  ; lots:

2026-01-15 mysterious
    assets:broker    10 AAPL
    income:mystery

$ hledger -f- bal assets --lots 2>&1
> !/was not classified/
>=0

# ** 7. Non-lotful commodity in asset account does not warn.
<
2026-01-15 normal
    assets:checking    $100
    income:salary

$ hledger -f- bal assets --lots-warn 2>&1
> !/was not classified/
>=0

# ** 8. Gain posting does not trigger unclassified warning.
<
account revenue:gains  ; type:V

2026-01-15 buy
    assets:stocks    10 AAPL {$50}
    assets:cash

2026-02-01 sell
    assets:stocks    -5 AAPL {$50} @ $60
    assets:cash      $300
    revenue:gains

$ hledger -f- bal assets --lots-warn 2>&1
> !/was not classified/
>=0
